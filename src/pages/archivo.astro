---
/**
 * /archivo — Canvas navegable (Página 2 del redesign).
 * Reemplaza la lista WorkArchive con un canvas 2D libre.
 *
 * El sidebar muestra contexto de archivo (contador + instrucciones nav).
 * No tiene scroll convencional — el contenido vive en el canvas.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import SidebarContextArchive from '../components/global/SidebarContextArchive.astro';
import Canvas from '../components/archive/Canvas.tsx';
---
<BaseLayout
  title="Archivo — Juan Cruz Luna"
  description="El archivo: proyectos, artefactos, notas. Drag para explorar."
  lang="es"
>
  <SidebarContextArchive slot="sidebar-context" />

  <Canvas client:load />
</BaseLayout>

<style>
  /* El canvas usa toda la altura del .site-main, sin padding extra. */
  :global(.site-main:has([data-canvas-page])) {
    padding-top: var(--ticker-height);
  }

  /* Anular padding heredado de site-main para el canvas */
  main.site-main > :first-child:not(:global(footer)) {
    margin: 0;
  }
</style>
