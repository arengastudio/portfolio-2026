---
/**
 * archivo.astro
 * All-works archive — every project, no case studies required.
 * List format with floating hover image + description panel.
 * Linked from SelectedWork "VER ARCHIVO COMPLETO →".
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/ui/Container.astro';
import Type from '../components/ui/Type.astro';
import ScrollReveal from '../components/motion/ScrollReveal.tsx';
import WorkArchive from '../components/work/WorkArchive.tsx';
import Footer from '../components/global/Footer.astro';
import styles from './archivo.module.css';
import { works } from '../data/works';
---
<BaseLayout
  title="Archivo — Juan Cruz Luna"
  description="Todos los proyectos. Sin filtros."
  lang="es"
>
  <section class={styles.page}>
    <Container>

      {/* ─── Header ─── */}
      <ScrollReveal client:visible variant="clip-up">
        <div class={styles.header}>
          <Type as="h1" variant="display-md" class={styles.title}>TRABAJO.</Type>
          <Type as="p" variant="xs" color="muted" class={styles.subtitle}>
            TODOS LOS PROYECTOS · 2017–2026
          </Type>
        </div>
      </ScrollReveal>

      {/* ─── Archive list ─── */}
      <WorkArchive client:load items={works} lang="es" />

    </Container>
  </section>

  <Footer />
</BaseLayout>
