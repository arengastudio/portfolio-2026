---
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../../components/ui/Container.astro';
import Type from '../../components/ui/Type.astro';
import Link from '../../components/ui/Link.astro';
import CaseHero from '../../components/case/CaseHero.astro';
import TLDR from '../../components/case/TLDR.astro';
import FigmaBanner from '../../components/case/FigmaBanner.astro';
import Footer from '../../components/global/Footer.astro';
import ReadingProgress from '../../components/motion/ReadingProgress.tsx';
import CaseHeroParallax from '../../components/motion/CaseHeroParallax.tsx';
import styles from './case.module.css';

export async function getStaticPaths() {
  /*
   * Only generate routes for:
   *   - locale: 'es'  (EN routes handled by /en/work/[slug] — future i18n)
   *   - slug !== ''   (excludes the _template.mdx stub)
   */
  const entries = await getCollection('cases', ({ data }) =>
    data.locale === 'es' && data.slug !== ''
  );

  return entries.map((entry) => ({
    params: { slug: entry.data.slug },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<'cases'>;
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { title, role, timeframe, outcome, client, team, platforms, tags, colorKey, coverImage, figmaDeepDive, bullets, figmaBannerLabel, figmaBannerUrl } = entry.data;
---
<BaseLayout
  title={`${title} - Juan Cruz Luna`}
  description={outcome}
  lang="es"
>
  <ReadingProgress client:load lang="es" />
  <CaseHeroParallax client:load />

  {/* ─── Block 1: Hero ─── */}
  <CaseHero
    title={title}
    role={role}
    timeframe={timeframe}
    outcome={outcome}
    client={client}
    colorKey={colorKey}
    image={coverImage}
  />

  {/* ─── Block 2: TL;DR ─── */}
  <TLDR
    client={client}
    role={role}
    team={team}
    timeframe={timeframe}
    platforms={platforms}
    tags={tags}
    outcome={outcome}
    bullets={bullets}
  />

  {/* ─── Blocks 3–9: MDX prose body ─── */}
  <div class={styles.proseClip}>
    <Container>
      <div class={styles.prose}>
        <Content />
      </div>

      {/* ─── Deep dive link (if Figma WorkBook exists) ─── */}
      {figmaDeepDive && (
        <div class={styles.deepDive}>
          <Type as="p" variant="xs" color="muted" class={styles.deepDiveLabel}>DEEP DIVE</Type>
          <Link href={figmaDeepDive} variant="standalone">
            Ver el trabajo en Figma →
          </Link>
        </div>
      )}
    </Container>
  </div>

  {/* ─── Figma / Proto banner ─── */}
  {figmaBannerLabel && (
    <FigmaBanner label={figmaBannerLabel} url={figmaBannerUrl ?? '#'} />
  )}

  <Footer />
</BaseLayout>
