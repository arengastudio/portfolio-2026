---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../../components/ui/Container.astro';
import Type from '../../components/ui/Type.astro';
import CaseEntry from '../../components/home/CaseEntry.astro';
import Footer from '../../components/global/Footer.astro';
import styles from './index.module.css';
import { works } from '../../data/works';

const cases = [
  {
    number: '01',
    title: 'Librodepases',
    year: '2022 — 2025',
    tags: 'AI · SPORTS · SAAS · DESIGN SYSTEM',
    role: 'PRODUCT DESIGN LEAD',
    tagline: 'Tres años liderando diseño en una plataforma que centraliza datos, video e IA para que los equipos de scouting de fútbol tomen mejores decisiones. De interfaz sin sistema a producto con design system propio.',
    href: '/work/librodepases',
    colorKey: 'accent' as const,
    image: '/assets/cases/librodepases/01.png',
  },
  {
    number: '02',
    title: 'SparkClub',
    year: '2025',
    tags: 'AI · EMPLOYEE ENGAGEMENT · MVP · END-TO-END',
    role: 'PRODUCT DESIGNER',
    tagline: 'MVP end-to-end para una plataforma de employee engagement con IA. Tres roles de usuario, design system desde cero, y prototipo interactivo listo para pitch a inversores. De brief a prototipo navegable en 6 semanas.',
    href: '/work/sparkclub',
    colorKey: 'fg' as const,
    image: '/assets/cases/sparkclub/cover.png',
  },
  {
    number: '03',
    title: 'Garantear',
    year: '2025',
    tags: 'FINTECH · BRAND',
    role: 'END-TO-END DESIGN',
    tagline: 'End-to-end product design para una fintech de garantías de alquiler en Argentina. Desde identidad visual hasta flujos de onboarding, firma digital y panel para inmobiliarias.',
    href: '/work/garantear',
    colorKey: 'dark' as const,
    image: '/assets/cases/garantear/01.png',
  },
];

const archive = works.slice(3);
---
<BaseLayout
  title="Work — Juan Cruz Luna"
  description="Casos seleccionados y archivo de proyectos de Juan Cruz Luna."
  lang="es"
>

  {/* ─── Hero ─── */}
  <section class={styles.hero}>
    <Container>
      <Type as="h1" variant="display-md" class={styles.heroTitle}>Work.</Type>
      <Type as="p" variant="lg" color="muted" class={styles.heroSub}>
        Casos seleccionados y archivo de proyectos.
      </Type>
    </Container>
  </section>

  {/* ─── Case entries ─── */}
  <section class={styles.cases}>
    <Container>
      {cases.map((c) => (
        <CaseEntry
          number={c.number}
          title={c.title}
          year={c.year}
          tags={c.tags}
          role={c.role}
          tagline={c.tagline}
          href={c.href}
          colorKey={c.colorKey}
          image={c.image}
        />
      ))}
    </Container>
  </section>

  {/* ─── Archivo ─── */}
  <section class={styles.archive}>
    <Container>
      <Type as="h2" variant="xs" color="muted" class={styles.archiveLabel}>ARCHIVO</Type>
      <div class={styles.archiveList}>
        {archive.map((item) => (
          <div class={styles.archiveItem}>
            <Type as="p" variant="lg" class={styles.archiveName}>{item.title}</Type>
            <Type as="p" variant="xs" color="muted" class={styles.archiveYear}>{item.year}</Type>
          </div>
        ))}
      </div>
    </Container>
  </section>

  <Footer />
</BaseLayout>
