---
/*
 * EN /about shell — mirrors /about.astro.
 * TODO(juan): Translate bio paragraphs to English.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../../components/ui/Container.astro';
import Type from '../../components/ui/Type.astro';
import Footer from '../../components/global/Footer.astro';
import styles from '../about.module.css';

const experience = [
  {
    years: '2022–Present',
    role: 'Product Design Lead',
    company: 'Librodepases',
  },
  {
    years: '2024–Present',
    role: 'Co-founder & Product Designer',
    company: 'Arenga Studio',
  },
  {
    years: '2021–2024',
    role: 'UX/UI Designer',
    company: 'Freelance',
  },
  {
    years: '2017–2021',
    role: 'Graphic design & print',
    company: 'Entre Ríos',
  },
];
---
<BaseLayout
  title="About — Juan Cruz Luna"
  description="Product Designer & Builder. Buenos Aires."
  lang="en"
>

  {/* ─── Hero ─── */}
  <section class={styles.hero}>
    <Container>
      <Type as="h1" variant="display-md" class={styles.heroTitle}>About.</Type>
      <Type as="p" variant="lg" color="muted" class={styles.heroSub}>
        Product Designer & Builder. Buenos Aires.
      </Type>
    </Container>
  </section>

  {/* ─── Photo + Bio ─── */}
  <section class={styles.intro}>
    <Container>

      {/* LEFT: photo placeholder */}
      <div class={styles.photoBlock} role="img" aria-label="Photo of Juan Cruz Luna — coming soon">
        <Type as="p" variant="xs" color="muted" class={styles.photoLabel}>[PHOTO]</Type>
      </div>

      {/* RIGHT: bio — TODO(juan): translate to English */}
      <div class={styles.bio}>
        <Type as="p" variant="base" class={styles.bioPara}>
          I'm Juan Cruz Luna. I design digital products from Buenos Aires. Started in Entre Ríos
          doing print and graphic design — now leading product design at Librodepases, an AI
          platform for football scouting.
        </Type>
        <Type as="p" variant="base" class={styles.bioPara}>
          In 2024 I co-founded Arenga Studio, a digital studio where we design and build products
          for startups and growing companies. I work end-to-end: strategy, research, UI, design
          systems, and implementation.
        </Type>
        <Type as="p" variant="base" class={styles.bioPara}>
          I believe designers who build make better design. That's why I don't just design — I also
          build. This site is my own code, not a template.
        </Type>
      </div>

    </Container>
  </section>

  {/* ─── Experience ─── */}
  <section class={styles.experience}>
    <Container>
      <Type as="h2" variant="xs" color="muted" class={styles.experienceLabel}>EXPERIENCE</Type>
      <div class={styles.experienceList}>
        {experience.map((item) => (
          <div class={styles.expItem}>
            <Type as="p" variant="xs" color="muted" class={styles.expYear}>{item.years}</Type>
            <div>
              <Type as="p" variant="lg" class={styles.expRole}>{item.role}</Type>
              <Type as="p" variant="base" color="muted" class={styles.expCompany}>{item.company}</Type>
            </div>
          </div>
        ))}
      </div>
    </Container>
  </section>

  <Footer lang="en" />
</BaseLayout>
