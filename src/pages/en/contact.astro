---
/*
 * EN /contact shell — mirrors /contact.astro.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../../components/ui/Container.astro';
import Type from '../../components/ui/Type.astro';
import Footer from '../../components/global/Footer.astro';
import styles from '../contact.module.css';
---
<BaseLayout
  title="Contact — Juan Cruz Luna"
  description="Let's talk. juancruzluna@arengastudio.com"
  lang="en"
>

  <section class={styles.hero}>
    <Container>

      <Type as="p" variant="xs" color="muted" class={styles.label}>CONTACT</Type>

      <Type as="h1" variant="display-md" class={styles.headline}>Let's talk.</Type>

      <a
        href="mailto:juancruzluna@arengastudio.com"
        class={styles.emailLink}
      >
        juancruzluna@arengastudio.com
      </a>

      <Type as="p" variant="base" color="muted" class={styles.note}>
        The contact form is an email. Maximum zero friction.
      </Type>

    </Container>
  </section>

  <Footer lang="en" />
</BaseLayout>
