---
/**
 * EN /work/[slug] — renders EN case MDX when available, falls back to ES.
 *
 * Priority: if locale='en' MDX exists for a slug, use it.
 * Otherwise render ES content with lang="en" on <html>.
 */
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Container from '../../../components/ui/Container.astro';
import Type from '../../../components/ui/Type.astro';
import Link from '../../../components/ui/Link.astro';
import CaseHero from '../../../components/case/CaseHero.astro';
import TLDR from '../../../components/case/TLDR.astro';
import FigmaBanner from '../../../components/case/FigmaBanner.astro';
import Footer from '../../../components/global/Footer.astro';
import ReadingProgress from '../../../components/motion/ReadingProgress.tsx';
import CaseHeroParallax from '../../../components/motion/CaseHeroParallax.tsx';
import styles from '../../work/case.module.css';

export async function getStaticPaths() {
  const enEntries = await getCollection('cases', ({ data }) =>
    data.locale === 'en' && data.slug !== ''
  );
  const esEntries = await getCollection('cases', ({ data }) =>
    data.locale === 'es' && data.slug !== ''
  );

const enSlugs = new Set(enEntries.map(e => e.data.slug));

  return [
    ...enEntries.map(entry => ({ params: { slug: entry.data.slug }, props: { entry } })),
    ...esEntries
      .filter(entry => !enSlugs.has(entry.data.slug))
      .map(entry => ({ params: { slug: entry.data.slug }, props: { entry } })),
  ];
}

interface Props {
  entry: CollectionEntry<'cases'>;
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { title, role, timeframe, outcome, client, team, platforms, tags, colorKey, coverImage, figmaDeepDive, bullets, figmaBannerLabel, figmaBannerUrl } = entry.data;
---
<BaseLayout
  title={`${title} — Juan Cruz Luna`}
  description={outcome}
  lang="en"
>
  <ReadingProgress client:load lang="en" />
  <CaseHeroParallax client:load />

  {/* ─── Block 1: Hero ─── */}
  <CaseHero
    title={title}
    role={role}
    timeframe={timeframe}
    outcome={outcome}
    client={client}
    colorKey={colorKey}
    image={coverImage}
    lang="en"
  />

  {/* ─── Block 2: TL;DR ─── */}
  <TLDR
    client={client}
    role={role}
    team={team}
    timeframe={timeframe}
    platforms={platforms}
    tags={tags}
    outcome={outcome}
    bullets={bullets}
    lang="en"
  />

  {/* ─── Blocks 3–9: MDX prose body ─── */}
  <div class={styles.proseClip}>
    <Container>
      <div class={styles.prose}>
        <Content />
      </div>

      {/* ─── Deep dive link (if Figma WorkBook exists) ─── */}
      {figmaDeepDive && (
        <div class={styles.deepDive}>
          <Type as="p" variant="xs" color="muted" class={styles.deepDiveLabel}>DEEP DIVE</Type>
          <Link href={figmaDeepDive} variant="standalone">
            See the work in Figma →
          </Link>
        </div>
      )}
    </Container>
  </div>

  {/* ─── Figma / Proto banner ─── */}
  {figmaBannerLabel && (
    <FigmaBanner label={figmaBannerLabel} url={figmaBannerUrl ?? '#'} lang="en" />
  )}

  <Footer lang="en" />
</BaseLayout>
