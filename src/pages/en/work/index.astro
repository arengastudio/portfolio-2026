---
/*
 * EN /work shell — mirrors /work/index.astro.
 * Href links point to EN case slugs once those exist.
 * TODO(juan): Translate copy and update case taglines to English.
 */
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Container from '../../../components/ui/Container.astro';
import Type from '../../../components/ui/Type.astro';
import CaseEntry from '../../../components/home/CaseEntry.astro';
import Footer from '../../../components/global/Footer.astro';
import styles from '../../work/index.module.css';
import { works } from '../../../data/works';

const cases = [
  {
    number: '01',
    title: 'Librodepases',
    year: '2022 — 2025',
    tags: 'AI · SPORTS · SAAS · DESIGN SYSTEM',
    role: 'PRODUCT DESIGN LEAD',
    tagline: 'Three years leading design on a platform centralizing data, video, and AI for football scouting teams. From a system-less interface to a product with its own design system.',
    href: '/work/librodepases',
    colorKey: 'accent' as const,
    image: '/assets/cases/librodepases/01.png',
  },
  {
    number: '02',
    title: 'SparkClub',
    year: '2025',
    tags: 'AI · EMPLOYEE ENGAGEMENT · MVP · END-TO-END',
    role: 'PRODUCT DESIGNER',
    tagline: 'End-to-end MVP for an AI-powered employee engagement platform. Three user roles, design system from scratch, and an interactive prototype ready for investor pitch. From brief to navigable prototype in 6 weeks.',
    href: '/work/sparkclub',
    colorKey: 'fg' as const,
    image: '/assets/cases/sparkclub/cover.png',
  },
  {
    number: '03',
    title: 'Garantear',
    year: '2025',
    tags: 'FINTECH · BRAND',
    role: 'END-TO-END DESIGN',
    tagline: 'End-to-end product design for a rental guarantee fintech in Argentina. From visual identity to onboarding flows, digital signing, and a real estate agency dashboard.',
    href: '/work/garantear',
    colorKey: 'dark' as const,
    image: '/assets/cases/garantear/01.png',
  },
];

const archive = works.slice(3);
---
<BaseLayout
  title="Work — Juan Cruz Luna"
  description="Selected cases and project archive by Juan Cruz Luna."
  lang="en"
>

  {/* ─── Hero ─── */}
  <section class={styles.hero}>
    <Container>
      <Type as="h1" variant="display-md" class={styles.heroTitle}>Work.</Type>
      <Type as="p" variant="lg" color="muted" class={styles.heroSub}>
        Selected cases and project archive.
      </Type>
    </Container>
  </section>

  {/* ─── Case entries ─── */}
  <section class={styles.cases}>
    <Container>
      {cases.map((c) => (
        <CaseEntry
          number={c.number}
          title={c.title}
          year={c.year}
          tags={c.tags}
          role={c.role}
          tagline={c.tagline}
          href={c.href}
          colorKey={c.colorKey}
          image={c.image}
        />
      ))}
    </Container>
  </section>

  {/* ─── Archive ─── */}
  <section class={styles.archive}>
    <Container>
      <Type as="h2" variant="xs" color="muted" class={styles.archiveLabel}>ARCHIVE</Type>
      <div class={styles.archiveList}>
        {archive.map((item) => (
          <div class={styles.archiveItem}>
            <Type as="p" variant="lg" class={styles.archiveName}>{item.title}</Type>
            <Type as="p" variant="xs" color="muted" class={styles.archiveYear}>{item.year}</Type>
          </div>
        ))}
      </div>
    </Container>
  </section>

  <Footer />
</BaseLayout>
