const categories = [
  {
    label: 'DESIGN',
    tools: [
      { name: 'Figma', note: 'Product design, prototypes, design systems', icon: 'figma' },
      { name: 'Framer', note: 'Sites and landing pages', icon: 'framer' },
      { name: 'Photoshop + Illustrator', note: 'Graphics, retouching, assets', icon: null },
    ],
  },
  {
    label: 'DEVELOPMENT',
    tools: [
      { name: 'Astro', note: 'This site', icon: null },
      { name: 'React', note: 'Interactive components', icon: null },
      { name: 'CSS Modules', note: 'Styling without abstractions', icon: null },
      { name: 'GSAP + Lenis', note: 'Motion and smooth scroll', icon: null },
      { name: 'Vercel', note: 'Deploy and hosting', icon: 'vercel' },
      { name: 'Claude Code', note: 'AI-assisted development', icon: null },
    ],
  },
  {
    label: 'PRODUCTIVITY',
    tools: [
      { name: 'Notion', note: 'Documentation and management', icon: 'notion' },
      { name: 'Linear', note: 'Project management', icon: 'linear' },
      { name: 'Slack + Discord', note: 'Communication', icon: null },
      { name: 'GitHub', note: 'Code and version control', icon: 'github' },
    ],
  },
];
---
<BaseLayout
  title="Stack - Juan Cruz Luna"
  description="The tools I use to design and build."
  lang="en"
>

  {/* ─── Hero ─── */}
  <section class={styles.hero}>
    <Container>
      <Type as="h1" variant="display-md" class={styles.heroTitle}>Stack.</Type>
      <Type as="p" variant="lg" color="muted" class={styles.heroSub}>
        The tools I use to design and build.
      </Type>
    </Container>
  </section>

  {/* ─── Categories ─── */}
  <section class={styles.categories}>
    <Container>
      {categories.map((cat) => (
        <div class={styles.category}>
          <Type as="h2" variant="xs" color="muted" class={styles.categoryLabel}>{cat.label}</Type>
          <div class={styles.toolGrid}>
            {cat.tools.map((tool) => (
              <div class={styles.toolCard}>
                {tool.icon && icons[tool.icon] && (
                  <svg
                    class={styles.toolIcon}
                    viewBox="0 0 24 24"
                    fill="currentColor"
                    aria-hidden="true"
                  >
                    <path d={icons[tool.icon]} />
                  </svg>
                )}
                <div class={styles.toolText}>
                  <Type as="p" variant="base" class={styles.toolName}>{tool.name}</Type>
                  <Type as="p" variant="xs" color="muted" class={styles.toolNote}>{tool.note}</Type>
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </Container>
  </section>

  <Footer lang="en" />
</BaseLayout>
