---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/ui/Container.astro';
import Type from '../components/ui/Type.astro';
import Footer from '../components/global/Footer.astro';
import styles from './lab.module.css';

const experiments = [
  {
    name: 'Scroll Animations',
    desc: 'Exploraciones con GSAP ScrollTrigger y Lenis.',
    colorKey: 'accent' as const,
  },
  {
    name: 'Design System Tokens',
    desc: 'Del DESIGN.md al CSS: un pipeline de tokens.',
    colorKey: 'fg' as const,
  },
  {
    name: 'AI Prototyping',
    desc: 'Prototipos rápidos con Claude y generación de código.',
    colorKey: 'dark' as const,
  },
  {
    name: 'WebGL Experiments',
    desc: 'Shaders, particles y cosas que brillan.',
    colorKey: 'accent' as const,
  },
];
---
<BaseLayout
  title="Lab — Juan Cruz Luna"
  description="Experimentos, prototipos y cosas que no encajan en ningún lado."
  lang="es"
>

  {/* ─── Hero ─── */}
  <section class={styles.hero}>
    <Container>
      <Type as="h1" variant="display-md" class={styles.heroTitle}>Lab.</Type>
      <Type as="p" variant="lg" color="muted" class={styles.heroSub}>
        Experimentos, prototipos y cosas que no encajan en ningún lado.
      </Type>
    </Container>
  </section>

  {/* ─── Experiment cards ─── */}
  <section class={styles.experiments}>
    <Container>
      <div class={styles.grid}>
        {experiments.map((exp) => (
          <article class:list={[styles.card, styles[exp.colorKey]]}>
            <div class={styles.cardVisual}>
              <p class={styles.cardName}>{exp.name}</p>
            </div>
            <Type as="p" variant="sm" class={styles.cardDesc}>{exp.desc}</Type>
          </article>
        ))}
      </div>
    </Container>
  </section>

  <Footer />
</BaseLayout>
