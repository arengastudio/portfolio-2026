---
import BaseLayout from '../layouts/BaseLayout.astro';
import Loader from '../components/motion/Loader.tsx';
import Hero from '../components/home/Hero.astro';
import Marquee from '../components/home/Marquee.astro';
import Currently from '../components/home/Currently.astro';
import SelectedWork from '../components/home/SelectedWork.astro';
import AreFirst from '../components/home/AreFirst.astro';
import Philosophy from '../components/home/Philosophy.astro';
import FinalCTA from '../components/home/FinalCTA.astro';
import Footer from '../components/global/Footer.astro';
---
<BaseLayout
  title="Juan Cruz Luna — Product Designer & Builder"
  description="Product Designer & Builder. Buenos Aires."
  lang="es"
>
  {/* Splash loader — first visit only, sessionStorage prevents replay */}
  <Loader client:load />

  <Hero />
  <Marquee />
  <Currently />
  <SelectedWork />
  <AreFirst />
  <Philosophy />
  <FinalCTA />
  <Footer />
</BaseLayout>
