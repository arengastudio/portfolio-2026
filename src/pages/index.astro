---
/**
 * Homepage (redesign 2026).
 * Estructura:
 *   - Sidebar contextual (slot)
 *   - Bloque 1 — Hero above the fold
 *   - Bloque 2 — Línea de tiempo
 *   - Bloque 3 — Señales recientes
 *   - Bloque 4 — Ancla + transición a accent
 *   - Reconocimiento del visitante (Sistema Global 02, solo home)
 *   - Footer
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import SidebarContextHome from '../components/global/SidebarContextHome.astro';
import HeroBlock from '../components/home2026/HeroBlock.astro';
import ArchivoPreview from '../components/home2026/ArchivoPreview.astro';
import Timeline from '../components/home2026/Timeline.astro';
import RecentSignals from '../components/home2026/RecentSignals.astro';
import AnchorTransition from '../components/home2026/AnchorTransition.astro';
import VisitorRecognition from '../components/global/VisitorRecognition.tsx';
import Footer from '../components/global/Footer.astro';
---
<BaseLayout
  title="Juan Cruz Luna — Product Designer & Builder"
  description="Diseñador de producto y builder. Co-fundador de Arenga Studio. Buenos Aires."
  lang="es"
>
  <SidebarContextHome slot="sidebar-context" />

  <HeroBlock />
  <ArchivoPreview />
  <Timeline />
  <RecentSignals />
  <AnchorTransition />

  {/* Sistema Global 02 — Reconocimiento del visitante (solo home) */}
  <VisitorRecognition client:idle />

  <Footer />
</BaseLayout>
