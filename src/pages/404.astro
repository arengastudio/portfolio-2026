---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/ui/Container.astro';
import Type from '../components/ui/Type.astro';
import Link from '../components/ui/Link.astro';
import Footer from '../components/global/Footer.astro';
import styles from './404.module.css';
---
<BaseLayout
  title="404 — Juan Cruz Luna"
  lang="es"
>

  <section class={styles.page}>
    <Container>

      <Type as="p" variant="display-md" color="muted" class={styles.number}>404.</Type>

      <Type as="h1" variant="2xl" class={styles.headline}>
        Esta página no existe.
      </Type>

      <Type as="p" variant="base" color="muted" class={styles.sub}>
        Pero el resto del sitio sí. Puede que la URL esté mal escrita
        o que la página haya sido movida.
      </Type>

      <Link href="/" variant="standalone" class={styles.back}>
        ← Volver al inicio
      </Link>

    </Container>
  </section>

  <Footer />
</BaseLayout>
