---
import '../styles/tokens.css';
import '../styles/fonts.css';
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import SmoothScroll from '../components/motion/SmoothScroll.tsx';
import Cursor from '../components/motion/Cursor.tsx';
import Nav from '../components/global/Nav.astro';
import GridOverlay from '../components/dev/GridOverlay.astro';

export interface Props {
  /** Page title. Default: 'Juan Cruz Luna'. */
  title?: string;
  /** Page description for <meta name="description"> and OG/Twitter tags. */
  description?: string;
  /** HTML lang attribute. Default: 'es'. */
  lang?: 'es' | 'en';
  /** Canonical URL override. Defaults to current page URL. */
  canonical?: string;
  /** OG image path (absolute from root). Default: /assets/profile.png. */
  ogImage?: string;
  /** OG type. Default: 'website'. */
  ogType?: string;
}

const {
  title = 'Juan Cruz Luna',
  description,
  lang = 'es',
  canonical: canonicalOverride,
  ogImage = '/assets/profile.png',
  ogType = 'website',
} = Astro.props;

const siteUrl = 'https://www.juancruzluna.xyz';
const canonical = canonicalOverride ?? `${siteUrl}${Astro.url.pathname}`;
const ogImageAbsolute = ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`;

const currentPath = Astro.url.pathname;
const isHome = currentPath === '/' || currentPath === '/en';

// Hreflang alternates
const esPath = lang === 'en'
  ? (currentPath.replace(/^\/en/, '') || '/')
  : currentPath;
const enPath = lang === 'en'
  ? currentPath
  : (currentPath === '/' ? '/en' : `/en${currentPath}`);
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:image" content={ogImageAbsolute} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}
    <meta name="twitter:image" content={ogImageAbsolute} />

    <!-- Hreflang alternates -->
    <link rel="alternate" hreflang="es" href={`${siteUrl}${esPath}`} />
    <link rel="alternate" hreflang="en" href={`${siteUrl}${enPath}`} />
    <link rel="alternate" hreflang="x-default" href={`${siteUrl}${esPath}`} />

    <link rel="icon" type="image/svg+xml" href="/assets/LogoJuan.svg" />
    <title>{title}</title>
    <ClientRouter />
    {import.meta.env.DEV && <script is:inline src="https://mcp.figma.com/mcp/html-to-design/capture.js" async></script>}
  </head>
  <body>
    {/*
      Language redirect — only on first visit to the root.
      sessionStorage prevents re-triggering on subsequent navigations.
      Non-Spanish browsers land on /en; Spanish stays at /.
    */}
    {lang === 'es' && (
      <script is:inline>
        if (!sessionStorage.getItem('lang-set')) {
          sessionStorage.setItem('lang-set', 'true');
          var lang = navigator.language || 'en';
          if (!lang.startsWith('es') && window.location.pathname === '/') {
            window.location.replace('/en');
          }
        }
      </script>
    )}

    {/* Smooth scroll + GSAP ticker */}
    <SmoothScroll client:idle />

    {/* Custom cursor */}
    <Cursor client:load lang={lang} />

    {/* Grid overlay — press G to toggle column guides (dev only) */}
    {import.meta.env.DEV && <GridOverlay />}

    {/* Fixed nav */}
    <Nav currentPath={currentPath} isHome={isHome} />

    <a href="#main-content" class="skip-link">{lang === 'en' ? 'Skip to content' : 'Saltar al contenido'}</a>

    <main id="main-content" style={`padding-block-start: var(--nav-height)`}>
      <slot />
    </main>
  </body>
</html>

<script>
  /*
   * Dark section inversion — IntersectionObserver approach.
   * threshold: 0.15 fires when 15% of the section is visible.
   * Re-runs on astro:page-load so View Transitions don't orphan observers.
   */
  function initDarkSections() {
    const sections = document.querySelectorAll<HTMLElement>('[data-dark-section]');
    if (!sections.length) return;

    const activeSet = new Set<Element>();

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            activeSet.add(entry.target);
          } else {
            activeSet.delete(entry.target);
          }
        });

        const isDark = activeSet.size > 0;
        sections.forEach((el) => {
          el.classList.toggle('is-dark', isDark);
        });
      },
      { threshold: 0.15 }
    );

    sections.forEach((el) => observer.observe(el));

    document.addEventListener('astro:before-swap', () => observer.disconnect(), { once: true });
  }

  initDarkSections();
  document.addEventListener('astro:page-load', initDarkSections);
</script>

<script>
  /*
   * Console Easter egg — for the person who opens DevTools.
   * Intentionally runs in production: this is for curious developers visiting the site.
   */
  (function () {
    const style = {
      bold:  'font-weight: bold; font-size: 14px;',
      mono:  'font-family: monospace; font-size: 12px; color: #888;',
      reset: 'font-weight: normal; font-size: 12px;',
    };

    console.log(
      '%c👋 Ey, vos.',
      style.bold
    );
    console.log(
      '%cSí, vos: el que abrió la consola.\nSi llegaste hasta acá, probablemente sepas leer código.\nY si sabés leer código, probablemente seamos amigos.',
      style.reset
    );
    console.log(
      '%cGitHub: github.com/juancrluna',
      style.mono
    );
    console.log(
      '%cPD: el sitio está hecho en Astro. El cursor lo escribí yo. No me juzgues.',
      style.mono
    );
  })();
</script>
