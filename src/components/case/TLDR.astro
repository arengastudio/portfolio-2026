---
import Container from '../ui/Container.astro';
import Type from '../ui/Type.astro';
import styles from './TLDR.module.css';

export interface Props {
  client: string;
  role: string;
  team: string;
  timeframe: string;
  platforms: string[];
  tags: string[];
  outcome: string;
  /**
   * Optional qualitative impact bullets — rendered below the metadata grid.
   * Short statements, no percentages or specific figures.
   */
  bullets?: string[];
}

const { client, role, team, timeframe, platforms, bullets } = Astro.props;
---
<section class={styles.tldr} aria-label="Resumen del caso">
  <Container>

    {/* ─── Metadata grid ─── */}
    <div class={styles.grid}>

      <div class={styles.cell}>
        <Type as="p" variant="xs" color="muted" class={styles.cellLabel}>CLIENTE</Type>
        <Type as="p" variant="base" class={styles.cellValue}>{client}</Type>
      </div>

      <div class={styles.cell}>
        <Type as="p" variant="xs" color="muted" class={styles.cellLabel}>ROL</Type>
        <Type as="p" variant="base" class={styles.cellValue}>{role}</Type>
      </div>

      <div class={styles.cell}>
        <Type as="p" variant="xs" color="muted" class={styles.cellLabel}>EQUIPO</Type>
        <Type as="p" variant="base" class={styles.cellValue}>{team}</Type>
      </div>

      <div class={styles.cell}>
        <Type as="p" variant="xs" color="muted" class={styles.cellLabel}>PERÍODO</Type>
        <Type as="p" variant="base" class={styles.cellValue}>{timeframe}</Type>
      </div>

      <div class={styles.cell}>
        <Type as="p" variant="xs" color="muted" class={styles.cellLabel}>PLATAFORMAS</Type>
        <Type as="p" variant="base" class={styles.cellValue}>{platforms.join(', ')}</Type>
      </div>

    </div>

    {/* ─── Impact bullets ─── */}
    {/*
      Visible only when `bullets` is present in the case frontmatter.
      Short qualitative statements — no percentages, no invented figures.
      Each bullet has an accent dash prefix and plain base-size body text.
    */}
    {bullets && bullets.length > 0 && (
      <ul class={styles.bullets}>
        {bullets.map((bullet) => (
          <li class={styles.bullet}>
            <span class={styles.bulletDash} aria-hidden="true">—</span>
            <Type as="span" variant="base" class={styles.bulletText}>{bullet}</Type>
          </li>
        ))}
      </ul>
    )}

  </Container>
</section>
