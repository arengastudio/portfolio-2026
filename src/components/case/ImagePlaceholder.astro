---
export interface Props {
  src?: string;
  alt?: string;
  label?: string;
}
const { src, alt = '', label = 'Imagen' } = Astro.props;
---
{src
  ? <img src={src} alt={alt} class="case-image" />
  : (
    <div class="image-placeholder">
      <span class="image-placeholder-label">{label}</span>
    </div>
  )
}
