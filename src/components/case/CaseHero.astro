---
import Container from '../ui/Container.astro';
import Type from '../ui/Type.astro';
import { Image } from 'astro:assets';
import { resolveCaseImage } from '../../lib/caseImages';
import styles from './CaseHero.module.css';

export interface Props {
  title: string;
  role: string;
  timeframe: string;
  outcome: string;
  client: string;
  colorKey: 'accent' | 'fg' | 'dark';
  /** Path to the hero cover image (relative to /public). When provided, replaces the colored placeholder. */
  image?: string;
  lang?: 'es' | 'en';
  /** Zero-padded case number shown in meta row (e.g. '01', '04'). */
  caseNumber?: string;
}

const { title, role, timeframe, outcome, client, colorKey, image, lang = 'es', caseNumber } = Astro.props;
const resolvedImage = resolveCaseImage(image);
---
<section class={styles.hero} data-case-hero>
  <Container>

    {/* ─── Case number · Client · Role · Timeframe ─── */}
    <div class={styles.meta}>
      {caseNumber && (
        <>
          <Type as="p" variant="xs" color="muted" class={styles.metaItem}>{caseNumber}</Type>
          <span class={styles.metaSep} aria-hidden="true">·</span>
        </>
      )}
      <Type as="p" variant="xs" color="muted" class={styles.metaItem}>{client}</Type>
      <span class={styles.metaSep} aria-hidden="true">·</span>
      <Type as="p" variant="xs" color="muted" class={styles.metaItem}>{role}</Type>
      <span class={styles.metaSep} aria-hidden="true">·</span>
      <Type as="p" variant="xs" color="muted" class={styles.metaItem}>{timeframe}</Type>
    </div>

    {/* ─── Project title ─── */}
    <Type as="h1" variant="3xl" class={styles.title}>{title}</Type>

    {/* ─── One-line outcome ─── */}
    <Type as="p" variant="lg" class={styles.outcome}>{outcome}</Type>

    {/* ─── Visual block ─── */}
    {/* When coverImage is provided: renders the real photo. Fallback: colored placeholder block. */}
    <div class={styles.visualWrap}>
      {resolvedImage
        ? (
          <div class={styles.visualImg} data-case-visual>
            <Image
              src={resolvedImage}
              alt={lang === 'en' ? `${title}: project visual` : `Visual del proyecto ${title}`}
              class={styles.visualPhoto}
              decoding="async"
              loading="eager"
              priority
              format="webp"
              quality="high"
              widths={[480, 768, 1024, 1280, 1600]}
              sizes="(max-width: 767px) 100vw, min(100vw - 96px, 1280px)"
            />
          </div>
        )
        : (
          <div class:list={[styles.visual, styles[colorKey]]} data-case-visual role="img" aria-label={lang === 'en' ? `${title}: project visual` : `Visual del proyecto ${title}`}>
            <p class={styles.visualTitle} aria-hidden="true">{title}</p>
          </div>
        )
      }
    </div>

  </Container>
</section>
