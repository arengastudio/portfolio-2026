---
import Container from '../ui/Container.astro';
import Type from '../ui/Type.astro';
import styles from './CaseHero.module.css';

export interface Props {
  title: string;
  role: string;
  timeframe: string;
  outcome: string;
  client: string;
  colorKey: 'accent' | 'fg' | 'dark';
  /** Path to the hero cover image (relative to /public). When provided, replaces the colored placeholder. */
  image?: string;
}

const { title, role, timeframe, outcome, client, colorKey, image } = Astro.props;
---
<section class={styles.hero} data-case-hero>
  <Container>

    {/* ─── Client · Role · Timeframe ─── */}
    <div class={styles.meta}>
      <Type as="p" variant="xs" color="muted" class={styles.metaItem}>{client}</Type>
      <span class={styles.metaSep} aria-hidden="true">·</span>
      <Type as="p" variant="xs" color="muted" class={styles.metaItem}>{role}</Type>
      <span class={styles.metaSep} aria-hidden="true">·</span>
      <Type as="p" variant="xs" color="muted" class={styles.metaItem}>{timeframe}</Type>
    </div>

    {/* ─── Project title ─── */}
    <Type as="h1" variant="3xl" class={styles.title}>{title}</Type>

    {/* ─── One-line outcome ─── */}
    <Type as="p" variant="lg" class={styles.outcome}>{outcome}</Type>

    {/* ─── Visual block ─── */}
    {/*
      When coverImage is provided: renders the real photo.
      Fallback: colored placeholder block with watermark text.
      TODO(juan): swap fallback for <video autoplay muted loop playsinline>
      when screen recording is ready — keep the colorKey block as the poster.
    */}
    <div class={styles.visualWrap}>
      {image
        ? (
          <div class={styles.visualImg} data-case-visual>
            <img
              src={image}
              alt={`Visual del proyecto ${title}`}
              class={styles.visualPhoto}
              loading="eager"
              decoding="async"
            />
          </div>
        )
        : (
          <div class:list={[styles.visual, styles[colorKey]]} data-case-visual role="img" aria-label={`Visual del proyecto ${title}`}>
            <p class={styles.visualTitle} aria-hidden="true">{title}</p>
          </div>
        )
      }
    </div>

  </Container>
</section>
