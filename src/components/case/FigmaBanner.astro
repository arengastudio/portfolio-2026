---
/**
 * FigmaBanner.astro
 * Full-width accent banner at the end of each case study.
 * Links to the Figma workbook or interactive prototype in a new tab.
 *
 * Layout: two columns — left has the label (display) + bajada (mono),
 * right has the CTA link. Stacks vertically on mobile.
 *
 * Colors: accent background (#4B53F6) with cream text/border — inverts
 * the site palette to signal a clear break before the footer.
 */
import styles from './FigmaBanner.module.css';

export interface Props {
  /** CTA label — e.g. "Ver workbook" or "See workbook" */
  label: string;
  /** Destination URL. Opens in new tab. Use '#' as placeholder. */
  url: string;
  lang?: 'es' | 'en';
}

const { label, url, lang = 'es' } = Astro.props;

// Translate ES labels when the case falls back to ES MDX on EN routes
const displayLabel = lang === 'en'
  ? label
      .replace('Ver workbook', 'See workbook')
      .replace('Ver prototipo interactivo', 'View interactive prototype')
  : label;

const bajada = lang === 'en'
  ? 'Explore flows, real screens, and UI design from the Figma file.'
  : 'Visualizá flujos, pantallas reales y diseño UI del producto desde un archivo de Figma.';
---
<section class={styles.banner} aria-label={displayLabel}>
  <div class={styles.inner}>

    <div class={styles.left}>
      <p class={styles.label}>{displayLabel}</p>
      <p class={styles.bajada}>{bajada}</p>
    </div>

    <a
      href={url}
      target="_blank"
      rel="noopener noreferrer"
      class={styles.cta}
    >
      {displayLabel} →
    </a>

  </div>
</section>
