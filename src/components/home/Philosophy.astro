---
import Container from '../ui/Container.astro';
import Type from '../ui/Type.astro';
import PhilosophyPin from '../motion/PhilosophyPin.tsx';
import styles from './Philosophy.module.css';

export interface Props { lang?: 'es' | 'en' }
const { lang = 'es' } = Astro.props;

const principles = [
  {
    number: '01',
    statement: 'FUNCTION OVER POLISH.',
    bajada: lang === 'en'
      ? "If it doesn't solve a real problem, it's not design. It's decoration."
      : 'Si no resuelve un problema real, no es diseño. Es decoración.',
  },
  {
    number: '02',
    statement: "PIXELS ARE CHEAP. DECISIONS AREN'T.",
    bajada: lang === 'en'
      ? "Anyone can move pixels. Deciding which ones matter is the craft."
      : 'Cualquiera puede mover píxeles. Decidir cuáles importan es el oficio.',
  },
  {
    number: '03',
    statement: 'DESIGNERS WHO BUILD, BUILD BETTER.',
    bajada: lang === 'en'
      ? "Building what you design forces you to respect reality. And makes for better design."
      : 'Construir lo que diseñás te obliga a respetar la realidad. Y hace mejor diseño.',
  },
];
---
<section class={styles.philosophy} data-philosophy-section>
  <Container>

    {/*
      PhilosophyPin handles all animation:
      Desktop — pins the section and scrubs principles 2+3 in on scroll.
      Mobile / reduced-motion — simple fade-in per principle.
      data-principle={i+1} is the hook PhilosophyPin uses to target each article.
    */}
    <div class={styles.inner}>
      {principles.map((p, i) => (
        <article class={styles.principle} data-principle={i + 1}>
          {/* Decorative oversized number — editorial accent, aria-hidden */}
          <span class={styles.bgNumber} aria-hidden="true">{p.number}</span>
          <Type as="p" variant="xs" color="muted" class={styles.number}>{p.number}</Type>
          <Type as="p" variant="3xl" class={styles.statement}>{p.statement}</Type>
          <Type as="p" variant="base" color="muted" class={styles.bajada}>{p.bajada}</Type>
        </article>
      ))}
    </div>

  </Container>

  {/* Pin controller — renders nothing, pure GSAP side-effect */}
  <PhilosophyPin client:visible />
</section>

<style is:global>
  /*
   * Philosophy accent state — triggered by IntersectionObserver below.
   * Overrides CSS custom properties so all child type components
   * (which read var(--color-fg) / var(--color-muted)) update automatically.
   * border-top-color matches the new bg to erase the visual divider.
   */
  [data-philosophy-section] {
    transition:
      background-color 0.9s cubic-bezier(0.16, 1, 0.3, 1),
      border-top-color 0.9s cubic-bezier(0.16, 1, 0.3, 1);
  }

  [data-philosophy-section].philosophy-accent {
    background-color: var(--color-accent);
    border-top-color: var(--color-accent);
    --color-fg:     #F5F2EC;
    --color-muted:  rgba(245, 242, 236, 0.65);
    --color-border: rgba(245, 242, 236, 0.15);
  }

  @media (prefers-reduced-motion: reduce) {
    [data-philosophy-section] { transition: none; }
  }
</style>

<script>
  /*
   * Toggle .philosophy-accent on the section when 30% of it is visible.
   * Removes the class when the section leaves the viewport.
   * Re-runs on astro:page-load for View Transitions.
   */
  function initPhilosophyAccent() {
    const section = document.querySelector<HTMLElement>('[data-philosophy-section]');
    if (!section) return;

    const observer = new IntersectionObserver(
      ([entry]) => {
        section.classList.toggle('philosophy-accent', entry.isIntersecting);
      },
      { threshold: 0.3 }
    );

    observer.observe(section);
    document.addEventListener('astro:before-swap', () => observer.disconnect(), { once: true });
  }

  initPhilosophyAccent();
  document.addEventListener('astro:page-load', initPhilosophyAccent);
</script>
