---
import Container from '../ui/Container.astro';
import Type from '../ui/Type.astro';
import PhilosophyPin from '../motion/PhilosophyPin.tsx';
import styles from './Philosophy.module.css';

const principles = [
  {
    number: '01',
    statement: 'FUNCTION OVER POLISH.',
    bajada: 'Si no resuelve un problema real, no es diseño. Es decoración.',
  },
  {
    number: '02',
    statement: "PIXELS ARE CHEAP. DECISIONS AREN'T.",
    bajada: 'Cualquiera puede mover píxeles. Decidir cuáles importan es el oficio.',
  },
  {
    number: '03',
    statement: 'DESIGNERS WHO BUILD, BUILD BETTER.',
    bajada: 'Construir lo que diseñás te obliga a respetar la realidad. Y hace mejor diseño.',
  },
];
---
<section class={styles.philosophy} data-philosophy-section>
  <Container>

    {/*
      PhilosophyPin handles all animation:
      Desktop — pins the section and scrubs principles 2+3 in on scroll.
      Mobile / reduced-motion — simple fade-in per principle.
      data-principle={i+1} is the hook PhilosophyPin uses to target each article.
    */}
    <div class={styles.inner}>
      {principles.map((p, i) => (
        <article class={styles.principle} data-principle={i + 1}>
          {/* Decorative oversized number — editorial accent, aria-hidden */}
          <span class={styles.bgNumber} aria-hidden="true">{p.number}</span>
          <Type as="p" variant="xs" color="muted" class={styles.number}>{p.number}</Type>
          <Type as="p" variant="3xl" class={styles.statement}>{p.statement}</Type>
          <Type as="p" variant="base" color="muted" class={styles.bajada}>{p.bajada}</Type>
        </article>
      ))}
    </div>

  </Container>

  {/* Pin controller — renders nothing, pure GSAP side-effect */}
  <PhilosophyPin client:visible />
</section>
