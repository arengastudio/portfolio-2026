---
import Container from '../ui/Container.astro';
import Type from '../ui/Type.astro';
import Link from '../ui/Link.astro';
import LiveClock from './LiveClock.tsx';
import ScrollReveal from '../motion/ScrollReveal.tsx';
import styles from './Currently.module.css';

export interface Props { lang?: 'es' | 'en' }
const { lang = 'es' } = Astro.props;
---
<section class={styles.currently}>
  <Container>

    {/* ─── Meta row: eyebrow left, date right ─── */}
    <ScrollReveal client:visible variant="fade">
      <div class={styles.metaRow}>
        <Type as="span" variant="xs" color="muted" class={styles.eyebrow}>CURRENTLY</Type>
        <Type as="span" variant="xs" color="muted" class={styles.dateMeta}>{lang === 'en' ? 'APRIL 2026' : 'ABRIL 2026'}</Type>
      </div>
    </ScrollReveal>

    {/* ─── Three activity links ─── */}
    {/*
      ScrollReveal inside the nav — display:contents makes links direct flex
      children of nav, preserving gap and flex-direction from .activities.
      Stagger 0.1s: line 1 at 0s, line 2 at 0.1s, line 3 at 0.2s.
    */}
    <nav class={styles.activities} aria-label={lang === 'en' ? 'Current activity' : 'Actividad actual'}>
      <ScrollReveal client:visible variant="fade-up" stagger={0.1}>
        <Link href={lang === 'en' ? '/en/work/sparkclub' : '/work/sparkclub'} variant="standalone" class={styles.activityLink}>
          {lang === 'en' ? 'Building with AI. New projects, new ideas' : 'Buildeando con IA. Nuevos proyectos, nuevas ideas'} <span class={styles.arrow} aria-hidden="true">→</span>
        </Link>
        <Link href="https://arengastudio.com" variant="standalone" class={styles.activityLink}>
          {lang === 'en' ? 'Co-founder at Arenga Studio' : 'Co-fundador en Arenga Studio'} <span class={styles.arrow} aria-hidden="true">→</span>
        </Link>
        <Link href="#contact" variant="standalone" class={styles.activityLink}>
          {lang === 'en' ? 'Available for new projects' : 'Disponible para nuevos proyectos'} <span class={styles.arrow} aria-hidden="true">→</span>
        </Link>
      </ScrollReveal>
    </nav>

    {/* ─── Live clock ticker (React island) ─── */}
    <ScrollReveal client:visible variant="fade" delay={0.3}>
      <div class={styles.clockWrapper}>
        <span class={styles.clock}>
          <LiveClock client:only="react" />
        </span>
      </div>
    </ScrollReveal>

  </Container>
</section>
