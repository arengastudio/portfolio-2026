---
import Type from '../ui/Type.astro';
import Link from '../ui/Link.astro';
import HoverParallax from '../motion/HoverParallax.tsx';
import styles from './CaseEntry.module.css';

export interface Props {
  number: string;
  title: string;
  year: string;
  tags: string;
  role: string;
  tagline: string;
  href: string;
  /** Controls the visual block background: 'accent' | 'fg' | 'dark' */
  colorKey: 'accent' | 'fg' | 'dark';
  /** Optional thumbnail image path (relative to /public). Renders behind the title. */
  image?: string;
  lang?: 'es' | 'en';
}

const { number, title, year, tags, role, tagline, href, colorKey, image, lang = 'es' } = Astro.props;
---
<article class:list={[styles.caseEntry, styles[colorKey]]} data-case-color={colorKey} data-follow-cursor>

  {/* ─── LEFT: big number + stacked mono meta ─── */}
  <div class={styles.left}>
    <Type as="p" variant="display-md" class={styles.number}>{number}</Type>
    <div class={styles.meta}>
      <Type as="p" variant="xs" color="muted" class={styles.metaItem}>{year}</Type>
      <Type as="p" variant="xs" color="muted" class={styles.metaItem}>{tags}</Type>
      <Type as="p" variant="xs" color="muted" class={styles.metaItem}>{role}</Type>
    </div>
  </div>

  {/* ─── RIGHT: magazine-cover visual + tagline + link ─── */}
  <div class={styles.right}>
    {/*
      .visual is the containing block (aspect-ratio, bg-color, position:relative).
      When `image` is provided, it sits as a position:absolute layer below the title.
      HoverParallax MUST NOT wrap the <img> — it uses firstElementChild as the
      parallax target, which would move the photo instead of the title.
      The image is therefore placed directly inside .visual, before HoverParallax.
      HoverParallax gets wrapperClass={styles.visualContent} — a full-inset absolute
      div — so the title sits on top and shifts on mouse move.
    */}
    {/*
      Visual block is also wrapped in <a> so clicking the image redirects.
      aria-hidden + tabindex=-1: the CTA Link below is the accessible entry
      point — this link is for mouse users who click the image.
    */}
    <a href={href} class={styles.visualLink} aria-hidden="true" tabindex="-1">
      <div class:list={[styles.visual, styles[colorKey]]}>
        {image && (
          <img
            src={image}
            alt=""
            class={styles.visualImg}
            loading="lazy"
            decoding="async"
          />
        )}
        <HoverParallax client:visible wrapperClass={styles.visualContent}>
          <Type as="h3" variant="display-lg" class={styles.visualTitle}>{title}</Type>
        </HoverParallax>
      </div>
    </a>
    <Type as="p" variant="lg" class={styles.tagline}>{tagline}</Type>
    <Link href={href} variant="standalone" class={styles.cta}>{lang === 'en' ? 'VIEW CASE →' : 'VER CASO →'}</Link>
  </div>

</article>
