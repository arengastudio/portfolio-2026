---
import Container from '../ui/Container.astro';
import Type from '../ui/Type.astro';
import Button from '../ui/Button.astro';
import TrackRecord from './TrackRecord.astro';
import ScrollReveal from '../motion/ScrollReveal.tsx';
import WebGLHero from '../motion/WebGLHero.tsx';
import HeroWords from '../motion/HeroWords.tsx';
import TextScramble from '../motion/TextScramble.tsx';
import styles from './Hero.module.css';
---
<section data-hero class={styles.hero}>
  <WebGLHero client:visible wrapperClass={styles.webglCanvas} />
  <Container>

    {/* ─── LEFT — display statement, bottom-anchored ─── */}
    {/*
      HeroWord splits each word into chars and staggers them in with
      GSAP SplitText — y: 110 → 0, opacity 0 → 1, power4.out.
      Each word has a slight delay so they cascade: BUILD → BREAK → SHIP.

      The overflow:hidden span on each HeroWord clips the initial y offset,
      giving a "lift from below the baseline" reveal.

      Fires on page load (above the fold). Degrades on reduced-motion.
    */}
    <div class={styles.leftPanel}>
      <HeroWords client:load wordClass={styles.displayWord} />
    </div>

    {/* ─── RIGHT — identity + info, fades in after words ─── */}
    {/*
      Wraps the rightPanel div — display:contents keeps the div as a direct
      grid child with grid-column:5/9. Fires on page load (above fold),
      delay 1.2s lands after the statement finishes (0.3 + 3×0.15 + ~0.8s).
    */}
    <ScrollReveal client:load variant="fade" delay={1.2}>
      <div class={styles.rightPanel}>
        <TextScramble client:load text="Juan Cruz Luna" className={styles.name} />
        <Type as="p" variant="lg" class={styles.positioning}>Product Designer & Builder. Buenos Aires.</Type>
        <Type as="p" variant="base" color="fg" class={styles.subhead}>
          Diseño productos digitales. Y a veces los rompo a propósito.
        </Type>
        <div class={styles.trackWrapper}>
          <TrackRecord />
        </div>
        <div class={styles.ctas}>
          <Button variant="primary" href="/work">VER MI TRABAJO →</Button>
          <Button variant="secondary" href="#contact">Contactame</Button>
        </div>
      </div>
    </ScrollReveal>

  </Container>
</section>
