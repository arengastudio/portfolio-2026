---
import Container from '../ui/Container.astro';
import NavScroll from '../motion/NavScroll.tsx';
import styles from './Nav.module.css';

export interface Props {
  /** Current page path — used to apply active state to matching link. */
  currentPath?: string;
  /** True on the home page: nav hides after hero scrolls out. */
  isHome?: boolean;
}

const { currentPath = '/', isHome = false } = Astro.props;

/*
 * Language detection + switcher URL generation.
 * ES is the default locale (no prefix). EN lives at /en/*.
 * Strip /en prefix to get the canonical base path, then rebuild both URLs.
 */
const isEN = currentPath.startsWith('/en');
const basePath = isEN ? (currentPath.slice(3) || '/') : currentPath;
const esUrl   = basePath;
const enUrl   = basePath === '/' ? '/en' : `/en${basePath}`;
const activeLang = isEN ? 'en' : 'es';

/*
 * Links always point to the current-locale equivalent.
 * Active detection strips /en prefix before comparing.
 */
const makeLink = (base: string) => isEN ? `/en${base}` : base;

const links = [
  { href: makeLink('/work'),  label: 'work'  },
  { href: makeLink('/about'), label: 'about' },
  { href: makeLink('/stack'), label: 'stack' },
];

/*
 * Active detection: compare against locale-correct href.
 * /work/librodepases → work link active ✓
 * /en/about          → about link active ✓
 * /                  → no link active (brand-only home) ✓
 */
const isActive = (href: string) => currentPath.startsWith(href);
---

{/* data-nav — targeted by NavScroll.tsx to toggle data-nav-hidden */}
<header data-nav class={styles.nav}>
  <Container>
    <div class={styles.inner}>

      {/* Left — brand links to locale home */}
      <a href={isEN ? '/en' : '/'} class={styles.brand} aria-label="Juan Cruz Luna — Inicio">
        <img
          src="/assets/LogoJuan.svg"
          alt=""
          class={styles.brandLogo}
          width="24"
          height="24"
          aria-hidden="true"
        />
        <span class={styles.brandText}>Juan Cruz Luna</span>
      </a>

      {/* Right — primary navigation + language switcher */}
      <div class={styles.right}>
        <nav class={styles.links} aria-label="Navegación principal">
          {links.map((link) => (
            <a
              href={link.href}
              class:list={[styles.link, isActive(link.href) && styles.active]}
              aria-current={isActive(link.href) ? 'page' : undefined}
            >
              {link.label}
            </a>
          ))}
        </nav>

        {/* Language switcher — compact ES · EN */}
        <div class={styles.langSwitch} aria-label="Cambiar idioma">
          <a
            href={esUrl}
            hreflang="es"
            class:list={[styles.lang, activeLang === 'es' && styles.langActive]}
            aria-current={activeLang === 'es' ? 'true' : undefined}
          >ES</a>
          <span class={styles.langSep} aria-hidden="true">·</span>
          <a
            href={enUrl}
            hreflang="en"
            class:list={[styles.lang, activeLang === 'en' && styles.langActive]}
            aria-current={activeLang === 'en' ? 'true' : undefined}
          >EN</a>
        </div>
      </div>

    </div>
  </Container>
</header>

{/*
  NavScroll handles scroll-aware visibility.
  client:load — runs immediately so the nav responds from the first scroll event.
*/}
<NavScroll client:load isHome={isHome} />
