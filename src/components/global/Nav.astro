---
import Container from '../ui/Container.astro';
import styles from './Nav.module.css';

export interface Props {
  /** Current page path — used to apply active state to matching link. */
  currentPath?: string;
  /** True on the home page: nav hides after hero scrolls out. */
  isHome?: boolean;
}

const { currentPath = '/', isHome = false } = Astro.props;

/*
 * Language detection + switcher URL generation.
 * ES is the default locale (no prefix). EN lives at /en/*.
 * Strip /en prefix to get the canonical base path, then rebuild both URLs.
 */
const isEN = currentPath.startsWith('/en');
const basePath = isEN ? (currentPath.slice(3) || '/') : currentPath;
const esUrl   = basePath;
const enUrl   = basePath === '/' ? '/en' : `/en${basePath}`;
const activeLang = isEN ? 'en' : 'es';

/*
 * Links always point to the current-locale equivalent.
 * Active detection strips /en prefix before comparing.
 */
const makeLink = (base: string) => isEN ? `/en${base}` : base;

const links = [
  { href: makeLink('/work'),  label: 'work'  },
  { href: makeLink('/about'), label: 'about' },
  { href: makeLink('/stack'), label: 'stack' },
];

/*
 * Active detection: compare against locale-correct href.
 * /work/librodepases → work link active ✓
 * /en/about          → about link active ✓
 * /                  → no link active (brand-only home) ✓
 */
const isActive = (href: string) => currentPath.startsWith(href);
---

{/* data-nav — scroll script toggles data-nav-hidden; data-is-home enables hero-exit mode */}
<header data-nav class={styles.nav} data-is-home={isHome || null}>
  <Container>
    <div class={styles.inner}>

      {/* Left — brand links to locale home */}
      <a href={isEN ? '/en' : '/'} class={styles.brand} aria-label={isEN ? 'Juan Cruz Luna - Home' : 'Juan Cruz Luna - Inicio'}>
        <img
          src="/assets/LogoJuan.svg"
          alt=""
          class={styles.brandLogo}
          width="24"
          height="24"
          aria-hidden="true"
        />
        <span class={styles.brandText}>Juan Cruz Luna</span>
      </a>

      {/* Right — primary navigation + language switcher */}
      <div class={styles.right}>
        <nav class={styles.links} aria-label={isEN ? 'Main navigation' : 'Navegación principal'}>
          {links.map((link) => (
            <a
              href={link.href}
              class:list={[styles.link, isActive(link.href) && styles.active]}
              aria-current={isActive(link.href) ? 'page' : undefined}
            >
              {link.label}
            </a>
          ))}
        </nav>

        {/* Language switcher — compact ES · EN */}
        <div class={styles.langSwitch} aria-label={isEN ? 'Change language' : 'Cambiar idioma'}>
          <a
            href={esUrl}
            hreflang="es"
            class:list={[styles.lang, activeLang === 'es' && styles.langActive]}
            aria-current={activeLang === 'es' ? 'true' : undefined}
          >ES</a>
          <span class={styles.langSep} aria-hidden="true">·</span>
          <a
            href={enUrl}
            hreflang="en"
            class:list={[styles.lang, activeLang === 'en' && styles.langActive]}
            aria-current={activeLang === 'en' ? 'true' : undefined}
          >EN</a>
        </div>
      </div>

    </div>
  </Container>
</header>

<script>
  function initNavScroll() {
    const nav = document.querySelector('[data-nav]') as HTMLElement | null;
    if (!nav) return;

    const hide = () => nav.setAttribute('data-nav-hidden', '');
    const show = () => nav.removeAttribute('data-nav-hidden');
    const setScrolled = (v: boolean) => {
      if (v) nav.setAttribute('data-scrolled', '');
      else nav.removeAttribute('data-scrolled');
    };

    const isHome = nav.hasAttribute('data-is-home');
    let onScroll: () => void;

    if (isHome) {
      const hero = document.querySelector('[data-hero]') as HTMLElement | null;
      const threshold = () => hero ? hero.offsetHeight : Math.round(window.innerHeight * 0.85);
      onScroll = () => {
        const y = window.scrollY;
        setScrolled(y > 10);
        if (y > threshold()) hide(); else show();
      };
    } else {
      let lastY = window.scrollY;
      setScrolled(lastY > 10);
      onScroll = () => {
        const y = window.scrollY;
        setScrolled(y > 10);
        if (y > lastY && y > 80) hide(); else show();
        lastY = y;
      };
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    document.addEventListener('astro:before-swap', () => window.removeEventListener('scroll', onScroll), { once: true });
  }

  initNavScroll();
  document.addEventListener('astro:page-load', initNavScroll);
</script>
