---
import Container from '../ui/Container.astro';
import Type from '../ui/Type.astro';
import styles from './Footer.module.css';

/*
 * Activity grid — pseudo-random contribution graph.
 * Fixed seed (42) guarantees the same pattern on every render.
 * 24 cols × 7 rows. 5 levels: 0 = empty, 1–4 = progressively more opaque.
 */
const COLS = 24;
const ROWS = 7;
const LEVELS = 5;

function mulberry32(seed: number) {
  return function () {
    seed |= 0; seed = seed + 0x6D2B79F5 | 0;
    let t = Math.imul(seed ^ seed >>> 15, 1 | seed);
    t = t + Math.imul(t ^ t >>> 7, 61 | t) ^ t;
    return ((t ^ t >>> 14) >>> 0) / 4294967296;
  };
}

const rand = mulberry32(42);
const grid: number[][] = Array.from({ length: ROWS }, () =>
  Array.from({ length: COLS }, () => Math.floor(rand() * LEVELS))
);

const levelOpacity = [0.08, 0.28, 0.48, 0.70, 1.0];
---
<footer class={styles.footer} data-dark-section="footer">
  <Container>

    <div class={styles.footerGrid}>

      {/* ─── LEFT column — identity + tagline ─── */}
      <div class={styles.leftCol}>

        {/* Logo — white via filter (works for currentColor and hardcoded-fill SVGs) */}
        <img
          src="/assets/LogoJuan.svg"
          alt="Juan Cruz Luna"
          class={styles.footerLogo}
          width="32"
          height="32"
        />

        <Type as="p" variant="xs" color="muted" class={styles.tagline}>
          Hecho en Buenos Aires con café, brutalismo y una cantidad irresponsable de iteraciones.
        </Type>

        <Type as="p" variant="xs" color="muted" class={styles.thatsAll}>
          <em>That's all.</em>
        </Type>

      </div>

      {/* ─── RIGHT column — activity + stack ─── */}
      <div class={styles.rightCol}>

        {/* Activity block */}
        <div class={styles.activityBlock} aria-hidden="true">
          <span class={styles.sectionLabel}>ACTIVIDAD</span>
          <div class={styles.activityGrid}>
            {grid.map((row) =>
              row.map((level, _colIdx) => (
                <div
                  class={styles.activityCell}
                  style={`opacity: ${levelOpacity[level]}`}
                />
              ))
            )}
          </div>
        </div>

        {/* Stack block */}
        <div class={styles.stackBlock}>
          <span class={styles.sectionLabel}>STACK</span>
          <Type as="p" variant="xs" color="muted" class={styles.stackList}>
            Astro · Claude Code · Vercel ·{' '}
            <a
              href="https://pangrampangram.com/products/formula"
              target="_blank"
              rel="noopener noreferrer"
              class={styles.fontLink}
            >PP Formula</a>
            {' · '}
            <a
              href="https://pangrampangram.com/products/neue-montreal"
              target="_blank"
              rel="noopener noreferrer"
              class={styles.fontLink}
            >Neue Montreal</a>
            {' · '}JBM
          </Type>
        </div>

      </div>

    </div>

  </Container>
</footer>
