---
import Container from '../ui/Container.astro';
import Type from '../ui/Type.astro';
import Link from '../ui/Link.astro';
import styles from './Footer.module.css';

const year = new Date().getFullYear();

/*
 * Activity grid — pseudo-random contribution graph, visually similar to GitHub.
 * Fixed seed (42) guarantees the same pattern on every render.
 * Columns × rows = 52 × 7 (one year of weeks × days per week).
 * 5 levels: 0 = empty, 1–4 = progressively more opaque accent color.
 */
const COLS = 52;
const ROWS = 7;
const LEVELS = 5; // 0–4

// Simple seeded PRNG (mulberry32)
function mulberry32(seed: number) {
  return function () {
    seed |= 0; seed = seed + 0x6D2B79F5 | 0;
    let t = Math.imul(seed ^ seed >>> 15, 1 | seed);
    t = t + Math.imul(t ^ t >>> 7, 61 | t) ^ t;
    return ((t ^ t >>> 14) >>> 0) / 4294967296;
  };
}

const rand = mulberry32(42);
const grid: number[][] = Array.from({ length: ROWS }, () =>
  Array.from({ length: COLS }, () => Math.floor(rand() * LEVELS))
);

// Opacity per level: 0 = near-zero, 1–4 = increasing
const levelOpacity = [0.08, 0.28, 0.48, 0.70, 1.0];
---
<footer class={styles.footer} data-dark-section="footer">
  <Container>

    <div class={styles.row}>

      {/* Left — copyright */}
      <Type as="span" variant="xs" color="muted" class={styles.copy}>
        © {year} Juan Cruz Luna
      </Type>

      {/* Center — inline nav */}
      <nav class={styles.nav} aria-label="Navegación del sitio">
        <Link href="/work" variant="standalone">Work</Link>
        <span class={styles.sep} aria-hidden="true">·</span>
        <Link href="/about" variant="standalone">About</Link>
        <span class={styles.sep} aria-hidden="true">·</span>
        <Link href="/lab" variant="standalone">Lab</Link>
        <span class={styles.sep} aria-hidden="true">·</span>
        <Link href="/stack" variant="standalone">Stack</Link>
        <span class={styles.sep} aria-hidden="true">·</span>
        <Link href="/contact" variant="standalone">Contacto</Link>
      </nav>


    </div>

    {/* ─── Activity grid ─── */}
    {/*
      Symbolic contribution graph — 52 cols × 7 rows (1 year of weeks).
      Values generated with a fixed seed so the pattern is stable.
      Decorative only (aria-hidden).
    */}
    <div class={styles.activityBlock} aria-hidden="true">
      <div class={styles.activityMeta}>
        <span class={styles.activityLabel}>ACTIVIDAD</span>
        <span class={styles.activityLabel}>{year}</span>
      </div>
      <div class={styles.activityGrid}>
        {grid.map((row) =>
          row.map((level, colIdx) => (
            <div
              class={styles.activityCell}
              style={`opacity: ${levelOpacity[level]}`}
            />
          ))
        )}
      </div>
    </div>

    {/* ─── Bottom strip: tagline + stack ─── */}
    <div class={styles.bottom}>

      {/* Left — made-in statement */}
      <Type as="p" variant="xs" color="muted" class={styles.tagline}>
        Hecho en Buenos Aires con café, brutalismo y una cantidad irresponsable de iteraciones.
      </Type>

      {/* Right — stack with title */}
      <div class={styles.stackBlock}>
        <span class={styles.stackLabel}>STACK</span>
        <Type as="p" variant="xs" color="muted" class={styles.colofon}>
          Astro · Vercel · PP Formula · Neue Montreal · JBM
        </Type>
      </div>

    </div>

    {/* ─── That's all. ─── */}
    {/*
      Miranda Priestly. Cinephiles smile.
      Everyone else reads it as an elegant close.
    */}
    <Type as="p" variant="xs" color="muted" class={styles.thatsAll}>
      That's all.
    </Type>

  </Container>
</footer>
