---
/**
 * AnchorTransition.astro
 * Homepage Bloque 4 — Cierre + sello diagonal. Bg shift a accent al entrar.
 */
import SectionTab from './SectionTab.astro';
import styles from './home2026.module.css';
---
<div id="sec-cierre" class={styles.anchorWrap}>
  <SectionTab
    number="04"
    label="Cierre"
    filename="home/anchor.astro"
    date="2026-05-14"
    revision="FINAL"
  />

  <section class={styles.anchor} data-anchor-transition>
    <span class={styles.anchorStampDiagonal} aria-hidden="true">Fin de archivo</span>

    <h2 class={styles.anchorStatement}>Diseño productos. También los construyo.</h2>
    <a href="/archivo" class={styles.anchorCta}>→ Ver archivo</a>
  </section>
</div>

<script>
  function initAnchor() {
    const anchor = document.querySelector<HTMLElement>('[data-anchor-transition]');
    if (!anchor) return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) anchor.setAttribute('data-active', 'true');
          else anchor.removeAttribute('data-active');
        });
      },
      { threshold: 0.4 }
    );

    io.observe(anchor);
    document.addEventListener('astro:before-swap', () => io.disconnect(), { once: true });
  }

  initAnchor();
  document.addEventListener('astro:page-load', initAnchor);
</script>

<style is:global>
  [data-anchor-transition][data-active="true"] {
    background-color: var(--color-accent);
    color: var(--color-bg);
  }
</style>
