---
/**
 * AnchorTransition.astro
 * Homepage Bloque 4 — Cierre / manifesto.
 * Sin section tab. Textura grid + grain + bandas diagonales.
 * Bg shift a accent al entrar en viewport.
 */
import styles from './home2026.module.css';
---
<section id="sec-cierre" class={styles.anchor} data-anchor-transition>
  <div class={styles.anchorTexture} aria-hidden="true"></div>

  <span class={styles.anchorStampDiagonal} aria-hidden="true">Fin de archivo</span>

  <h2 class={styles.anchorStatement}>Diseño productos. También los construyo.</h2>
  <a href="/archivo" class={styles.anchorCta}>→ Ver archivo</a>

  <div class={styles.anchorFootnote} aria-hidden="true">
    <span>JUAN CRUZ LUNA</span>
    <span>—</span>
    <span>PORTFOLIO 2026</span>
    <span>—</span>
    <span>BUENOS AIRES</span>
  </div>
</section>

<script>
  function initAnchor() {
    const anchor = document.querySelector<HTMLElement>('[data-anchor-transition]');
    if (!anchor) return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) anchor.setAttribute('data-active', 'true');
          else anchor.removeAttribute('data-active');
        });
      },
      { threshold: 0.4 }
    );

    io.observe(anchor);
    document.addEventListener('astro:before-swap', () => io.disconnect(), { once: true });
  }

  initAnchor();
  document.addEventListener('astro:page-load', initAnchor);
</script>

<style is:global>
  [data-anchor-transition][data-active="true"] {
    background-color: var(--color-accent);
    color: var(--color-bg);
  }
</style>
