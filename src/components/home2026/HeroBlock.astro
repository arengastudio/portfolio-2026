---
/**
 * HeroBlock.astro
 * Homepage Bloque 1 — Above the fold liviano.
 * Strip header → nombre glitch → tagline → línea breve activa.
 * El "En producción" se mostró antes como file-table (parecía la obra completa).
 * Ahora es una línea, y el block de Archivo asume el rol de centerpiece.
 */
import SectionStrip from './SectionStrip.astro';
import styles from './home2026.module.css';

const activeBrief = ['Oncoliq', 'Prode 2026', '+3 proyectos'];
---
<section id="sec-index" class={styles.hero} aria-labelledby="home-hero-name">
  <SectionStrip
    left={[
      { label: '01', value: 'Index', tag: true },
      { label: 'ID', value: 'JCL-2026' },
      { value: 'Buenos Aires, AR' },
    ]}
    right={[
      { value: 'home/index.astro' },
      { value: '2026-05-14' },
      { label: 'Rev', value: '14' },
    ]}
  />

  <div class={styles.heroTop}>
    <h1 id="home-hero-name" class={styles.name}>
      <span class={styles.glitchWord}>Juan</span>{' '}<span class={styles.glitchWord}>Cruz</span>{' '}<span class={styles.glitchWord}>Luna</span>
    </h1>
    <p class={styles.tagline}>Product Designer · Co-founder @ Arenga Studio</p>
  </div>

  <div class={styles.heroActive}>
    <span class={styles.heroActiveLabel}>
      <span class={styles.heroActiveDot} aria-hidden="true"></span>
      En producción
    </span>
    <span class={styles.heroActiveList}>
      {activeBrief.map((t, i) => (
        <>
          {i > 0 && <span class={styles.heroActiveSep}>·</span>}
          <span>{t}</span>
        </>
      ))}
    </span>
    <a href="#sec-archivo" class={styles.heroActiveLink}>el archivo completo ↓</a>
  </div>

  <div class={styles.heroFoot}>
    <div class={styles.stamp} aria-hidden="true">
      <span class={styles.stampMain}>Arenga Studio</span>
      <span class={styles.stampSub}>Buenos Aires · MMXXVI</span>
    </div>
  </div>
</section>
